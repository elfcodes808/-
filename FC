-- ═══════════════════════════════════════════════
-- [FIX #13] SEARCH — actually filters elements by name
-- ═══════════════════════════════════════════════

function Amberium:_SetupSearch()
    self.SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = string.lower(self.SearchBox.Text)
        for _, entry in ipairs(self._allElements) do
            if query == "" then
                entry.Instance.Visible = true
            else
                entry.Instance.Visible = string.find(string.lower(entry.Name), query, 1, true) ~= nil
            end
        end
    end)
end

