-- TOGGLE COMPONENT
-- [FIX #11] Whole row is now clickable (TextButton container)
-- ═══════════════════════════════════════════════

function Amberium._CreateToggle(parent, config, sectionData, lib)
    config = config or {}

    local name = config.Name or "Toggle"
    local default = config.Default or false
    local warning = config.Warning or false
    local callback = config.Callback or function() end

    local toggled = default

    -- [FIX #11] Container is TextButton so the entire row is clickable
    local container = Util.Create("TextButton", {
        Name = "Toggle_" .. name,
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency = 1,
        AutoButtonColor = false,
        Text = "",
        LayoutOrder = #sectionData.Elements + 1,
        Parent = parent,
    })

    local labelOffset = 0
    if warning then
        local warnIcon = Util.Create("Frame", {
            Name = "WarningIcon",
            Position = UDim2.new(0, 0, 0.5, -7),
            Size = UDim2.new(0, 14, 0, 14),
            BackgroundColor3 = Theme.WarningRed,
            BackgroundTransparency = 0.85,
            Parent = container,
        })
        Util.AddCorner(warnIcon, 3)

        Util.Create("Frame", {
            Name = "WarnDot",
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(0, 6, 0, 6),
            BackgroundColor3 = Theme.WarningRed,
            Parent = warnIcon,
        })

        labelOffset = 20
    end

    local label = Util.Create("TextLabel", {
        Name = "Label",
        Position = UDim2.new(0, labelOffset, 0, 0),
        Size = UDim2.new(1, -50 - labelOffset, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = container,
    })

    -- Toggle switch (visual only — clicks go through container)
    local toggleBg = Util.Create("Frame", {
        Name = "ToggleBg",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 38, 0, 20),
        BackgroundColor3 = toggled and Theme.ToggleOn or Theme.ToggleOff,
        Parent = container,
    })
    Util.AddCorner(toggleBg, 10)

    local knob = Util.Create("Frame", {
        Name = "Knob",
        AnchorPoint = Vector2.new(0, 0.5),
        Position = toggled and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0),
        Size = UDim2.new(0, 14, 0, 14),
        BackgroundColor3 = Theme.ToggleKnob,
        Parent = toggleBg,
    })
    Util.AddCorner(knob, 7)

    local knobGlow = Util.Create("Frame", {
        Name = "KnobGlow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, 4, 1, 4),
        BackgroundColor3 = Theme.ToggleOn,
        BackgroundTransparency = toggled and 0.7 or 1,
        Parent = knob,
    })
    Util.AddCorner(knobGlow, 10)

    local function setToggle(state)
        toggled = state
        Util.Tween(toggleBg, {BackgroundColor3 = toggled and Theme.ToggleOn or Theme.ToggleOff}, AnimConfig.ToggleSpeed)
        Util.Tween(knob, {Position = toggled and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)}, AnimConfig.ToggleSpeed)
        Util.Tween(knobGlow, {BackgroundTransparency = toggled and 0.7 or 1}, AnimConfig.ToggleSpeed)
        callback(toggled)
    end

    -- Click anywhere on the row
    container.MouseButton1Click:Connect(function()
        setToggle(not toggled)
    end)

    container.MouseEnter:Connect(function()
        Util.Tween(label, {TextColor3 = Theme.TextAccent}, 0.1)
    end)
    container.MouseLeave:Connect(function()
        Util.Tween(label, {TextColor3 = Theme.TextPrimary}, 0.1)
    end)

    local toggleObj = {
        Set = function(_, state) setToggle(state) end,
        Get = function() return toggled end,
        Instance = container,
    }

    table.insert(sectionData.Elements, toggleObj)
    if lib then table.insert(lib._allElements, { Name = name, Instance = container }) end
    return toggleObj
end

-- ═══════════════════════════════════════════════
-- SLIDER COMPONENT
-- [FIX #1]  Knob 14px → 8px (hover: 10px)
-- [FIX #7]  Connections stored for cleanup
-- [FIX #8]  Removed fillGlow artifact
-- [FIX #12] Proper decimal formatting via Util.FormatNumber
-- ═══════════════════════════════════════════════

function Amberium._CreateSlider(parent, config, sectionData, lib)
    config = config or {}

    local name = config.Name or "Slider"
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or min
    local increment = config.Increment or 1
    local suffix = config.Suffix or ""
    local callback = config.Callback or function() end

    local value = default

    local container = Util.Create("Frame", {
        Name = "Slider_" .. name,
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1,
        LayoutOrder = #sectionData.Elements + 1,
        Parent = parent,
    })

    local topRow = Util.Create("Frame", {
        Name = "TopRow",
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Parent = container,
    })

    Util.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(0.6, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = topRow,
    })

    -- [FIX #12] Formatted value display
    local valueLabel = Util.Create("TextLabel", {
        Name = "ValueLabel",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(0.4, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = Util.FormatNumber(value, increment) .. suffix,
        TextColor3 = Theme.TextSecondary,
        TextSize = 11,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = topRow,
    })

    -- Thinner track (4px instead of 6px)
    local track = Util.Create("Frame", {
        Name = "Track",
        Position = UDim2.new(0, 0, 0, 23),
        Size = UDim2.new(1, 0, 0, 4),
        BackgroundColor3 = Theme.SliderTrack,
        Parent = container,
    })
    Util.AddCorner(track, 2)

    local fillPercent = (default - min) / (max - min)

    local fill = Util.Create("Frame", {
        Name = "Fill",
        Size = UDim2.new(fillPercent, 0, 1, 0),
        BackgroundColor3 = Theme.SliderFill,
        Parent = track,
    })
    Util.AddCorner(fill, 2)

    -- [FIX #8] fillGlow REMOVED — was a 4×14px artifact at end of fill bar

    -- [FIX #1] Slider knob: 14px → 8px
    local knob = Util.Create("Frame", {
        Name = "Knob",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(fillPercent, 0, 0.5, 0),
        Size = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = Theme.SliderKnob,
        ZIndex = 2,
        Parent = track,
    })
    Util.AddCorner(knob, 4)

    -- Generous invisible hit area
    local interactBtn = Util.Create("TextButton", {
        Name = "InteractBtn",
        Position = UDim2.new(0, -4, 0, -10),
        Size = UDim2.new(1, 8, 0, 24),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 3,
        Parent = track,
    })

    local sliding = false

    local function updateSlider(inputX)
        local trackPos = track.AbsolutePosition.X
        local trackSize = track.AbsoluteSize.X
        if trackSize == 0 then return end

        local relativeX = math.clamp((inputX - trackPos) / trackSize, 0, 1)
        local rawValue = min + (max - min) * relativeX
        value = math.floor(rawValue / increment + 0.5) * increment
        value = math.clamp(value, min, max)

        local percent = (value - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, 0, 0.5, 0)
        valueLabel.Text = Util.FormatNumber(value, increment) .. suffix
        callback(value)
    end

    interactBtn.MouseButton1Down:Connect(function()
        sliding = true
        updateSlider(Mouse.X)
    end)

    -- [FIX #7] Stored connections
    if lib then
        lib:_Connect(UserInputService.InputEnded, function(input)
            if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and sliding then
                sliding = false
                Util.Tween(knob, {Size = UDim2.new(0, 8, 0, 8)}, 0.1)
            end
        end)

        lib:_Connect(UserInputService.InputChanged, function(input)
            if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                updateSlider(input.Position.X)
            end
        end)
    end

    -- [FIX #1] Hover: 8px → 10px (was 14→16)
    interactBtn.MouseEnter:Connect(function()
        Util.Tween(knob, {Size = UDim2.new(0, 10, 0, 10)}, 0.1)
    end)
    interactBtn.MouseLeave:Connect(function()
        if not sliding then
            Util.Tween(knob, {Size = UDim2.new(0, 8, 0, 8)}, 0.1)
        end
    end)

    local sliderObj = {
        Set = function(_, newValue)
            value = math.clamp(newValue, min, max)
            local percent = (value - min) / (max - min)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            knob.Position = UDim2.new(percent, 0, 0.5, 0)
            valueLabel.Text = Util.FormatNumber(value, increment) .. suffix
            callback(value)
        end,
        Get = function() return value end,
        Instance = container,
    }

    table.insert(sectionData.Elements, sliderObj)
    if lib then table.insert(lib._allElements, { Name = name, Instance = container }) end
    return sliderObj
end

