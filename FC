function Amberium._CreateKeybind(parent, config, sectionData, lib)
    config = config or {}

    local name = config.Name or "Keybind"
    local default = config.Default or Enum.KeyCode.Unknown
    local callback = config.Callback or function() end

    local currentKey = default
    local listening = false

    local container = Util.Create("Frame", {
        Name = "Keybind_" .. name,
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency = 1,
        LayoutOrder = #sectionData.Elements + 1,
        Parent = parent,
    })

    Util.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, -70, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = container,
    })

    local keyBtn = Util.Create("TextButton", {
        Name = "KeyBtn",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 60, 0, 22),
        BackgroundColor3 = Theme.InputBg,
        AutoButtonColor = false,
        Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
        TextColor3 = Theme.TextSecondary,
        TextSize = 10,
        FontFace = Fonts.Medium,
        Parent = container,
    })
    Util.AddCorner(keyBtn, 4)
    Util.AddStroke(keyBtn, Theme.InputBorder, 1, 0.5)

    keyBtn.MouseButton1Click:Connect(function()
        listening = true
        keyBtn.Text = "..."
        Util.Tween(keyBtn, {BackgroundColor3 = Theme.AccentDark}, 0.1)
    end)

    if lib then
        lib:_Connect(UserInputService.InputBegan, function(input)
            if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                if input.KeyCode == Enum.KeyCode.Escape then
                    currentKey = Enum.KeyCode.Unknown
                    keyBtn.Text = "None"
                else
                    currentKey = input.KeyCode
                    keyBtn.Text = input.KeyCode.Name
                end
                Util.Tween(keyBtn, {BackgroundColor3 = Theme.InputBg}, 0.1)
                callback(currentKey)
            end
        end)
    end

    local keybindObj = {
        Set = function(_, key) currentKey = key; keyBtn.Text = key == Enum.KeyCode.Unknown and "None" or key.Name; callback(key) end,
        Get = function() return currentKey end,
        Instance = container,
    }

    table.insert(sectionData.Elements, keybindObj)
    if lib then table.insert(lib._allElements, { Name = name, Instance = container }) end
    return keybindObj
end

-- ═══════════════════════════════════════════════
-- MINIMIZE / TOGGLE
-- ═══════════════════════════════════════════════

function Amberium:_SetupKeybinds()
    self:_Connect(UserInputService.InputBegan, function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == self.MinimizeKey then
            self:Toggle()
        end
    end)
end

function Amberium:Toggle()
    self.Minimized = not self.Minimized
    if self.Minimized then
        Util.Tween(self.MainFrame, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}, AnimConfig.WindowOpenSpeed)
        Util.Tween(self.Shadow, {ImageTransparency = 1}, AnimConfig.WindowOpenSpeed)
    else
        Util.Tween(self.MainFrame, {Size = self.Size, BackgroundTransparency = 0}, AnimConfig.WindowOpenSpeed)
        Util.Tween(self.Shadow, {ImageTransparency = 0.4}, AnimConfig.WindowOpenSpeed)
    end
end

function Amberium:Minimize()
    self.Minimized = true
    Util.Tween(self.MainFrame, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}, AnimConfig.WindowOpenSpeed)
    Util.Tween(self.Shadow, {ImageTransparency = 1}, AnimConfig.WindowOpenSpeed)
end

function Amberium:Restore()
    self.Minimized = false
    Util.Tween(self.MainFrame, {Size = self.Size, BackgroundTransparency = 0}, AnimConfig.WindowOpenSpeed)
    Util.Tween(self.Shadow, {ImageTransparency = 0.4}, AnimConfig.WindowOpenSpeed)
end

