        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = container,
    })

    local inputBg = Util.Create("Frame", {
        Name = "InputBg",
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(1, 0, 0, 26),
        BackgroundColor3 = Theme.InputBg,
        Parent = container,
    })
    Util.AddCorner(inputBg, 6)
    local inputStroke = Util.AddStroke(inputBg, Theme.InputBorder, 1, 0.5)

    local textBox = Util.Create("TextBox", {
        Name = "TextBox",
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -20, 1, 0),
        BackgroundTransparency = 1,
        Text = default,
        PlaceholderText = placeholder,
        PlaceholderColor3 = Theme.TextMuted,
        TextColor3 = Theme.TextPrimary,
        TextSize = 11,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        Parent = inputBg,
    })

    textBox.Focused:Connect(function()
        Util.Tween(inputStroke, {Color = Theme.InputFocusBorder, Transparency = 0}, 0.15)
    end)
    textBox.FocusLost:Connect(function()
        Util.Tween(inputStroke, {Color = Theme.InputBorder, Transparency = 0.5}, 0.15)
        value = textBox.Text
        if numeric then
            value = tonumber(value) or 0
            textBox.Text = tostring(value)
        end
        callback(value)
    end)

    local inputObj = {
        Set = function(_, newVal) value = newVal; textBox.Text = tostring(newVal); callback(newVal) end,
        Get = function() return value end,
        Instance = container,
    }

    table.insert(sectionData.Elements, inputObj)
    if lib then table.insert(lib._allElements, { Name = name, Instance = container }) end
    return inputObj
end

