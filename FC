-- NOTIFICATION SYSTEM
-- ═══════════════════════════════════════════════

function Amberium:Notify(config)
    config = config or {}

    local title = config.Title or "Notification"
    local message = config.Message or ""
    local duration = config.Duration or 4
    local notifType = config.Type or "Info"

    local typeColors = {
        Info = Theme.InfoBlue,
        Success = Theme.SuccessGreen,
        Warning = Color3.fromRGB(220, 180, 40),
        Error = Theme.WarningRed,
    }
    local accentColor = typeColors[notifType] or Theme.InfoBlue

    if not self.NotifContainer then
        self.NotifContainer = Util.Create("Frame", {
            Name = "Notifications",
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -20, 1, -20),
            Size = UDim2.new(0, 280, 0, 400),
            BackgroundTransparency = 1,
            Parent = self.ScreenGui,
        })
        Util.AddListLayout(self.NotifContainer, Enum.FillDirection.Vertical, 6, Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Bottom)
    end

    local notifFrame = Util.Create("Frame", {
        Name = "Notif",
        Size = UDim2.new(1, 0, 0, 60),
        BackgroundColor3 = Theme.CardBg,
        ClipsDescendants = true,
        Parent = self.NotifContainer,
    })
    Util.AddCorner(notifFrame, 8)
    Util.AddStroke(notifFrame, Theme.CardBorder, 1, 0.5)

    Util.Create("Frame", {
        Name = "AccentBar",
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        Parent = notifFrame,
    })

    Util.Create("TextLabel", {
        Name = "Title",
        Position = UDim2.new(0, 14, 0, 8),
        Size = UDim2.new(1, -20, 0, 16),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        FontFace = Fonts.SemiBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notifFrame,
    })

    Util.Create("TextLabel", {
        Name = "Message",
        Position = UDim2.new(0, 14, 0, 26),
        Size = UDim2.new(1, -20, 0, 28),
        BackgroundTransparency = 1,
        Text = message,
        TextColor3 = Theme.TextSecondary,
        TextSize = 11,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = notifFrame,
    })

    notifFrame.Position = UDim2.new(1, 20, 0, 0)
    notifFrame.BackgroundTransparency = 1
    Util.Tween(notifFrame, {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0}, 0.3)

    task.delay(duration, function()
        Util.Tween(notifFrame, {Position = UDim2.new(1, 20, 0, 0), BackgroundTransparency = 1}, 0.3)
        task.delay(0.35, function()
            notifFrame:Destroy()
        end)
    end)
end

-- ═══════════════════════════════════════════════
-- DESTROY / CLEANUP  [FIX #7] All connections disconnected
-- ═══════════════════════════════════════════════

function Amberium:Destroy()
    for _, conn in ipairs(self.Connections) do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
    self.Connections = {}
    self._allElements = {}
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

