-- ═══════════════════════════════════════════════

function Amberium:AddTab(config)
    config = config or {}

    local tabName = config.Name or "Tab"
    local tabCategory = config.Category or nil
    local tabOrder = #self.Tabs + 1

    if tabCategory then
        local categoryExists = false
        for _, t in ipairs(self.Tabs) do
            if t.Category == tabCategory then
                categoryExists = true
                break
            end
        end
        if not categoryExists then
            self:_AddSidebarCategory(tabCategory, tabOrder * 10 - 5)
        end
    end

    local tabButton = Util.Create("TextButton", {
        Name = "Tab_" .. tabName,
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Theme.SidebarItemHover,
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        LayoutOrder = tabOrder * 10,
        Parent = self.SidebarScroll,
    })
    Util.AddCorner(tabButton, 6)

    local activeBar = Util.Create("Frame", {
        Name = "ActiveBar",
        Position = UDim2.new(0, 0, 0.15, 0),
        Size = UDim2.new(0, 3, 0.7, 0),
        BackgroundColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        Parent = tabButton,
    })
    Util.AddCorner(activeBar, 2)

    local iconDot = Util.Create("Frame", {
        Name = "IconDot",
        Position = UDim2.new(0, 12, 0.5, -4),
        Size = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = Theme.TextMuted,
        Parent = tabButton,
    })
    Util.AddCorner(iconDot, 4)

    local tabLabel = Util.Create("TextLabel", {
        Name = "TabLabel",
        Position = UDim2.new(0, 28, 0, 0),
        Size = UDim2.new(1, -34, 1, 0),
        BackgroundTransparency = 1,
        Text = tabName,
        TextColor3 = Theme.TextSecondary,
        TextSize = 12,
        FontFace = Fonts.Medium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabButton,
    })

    local contentPage = Util.Create("ScrollingFrame", {
        Name = "Page_" .. tabName,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.ScrollbarThumb,
        ScrollBarImageTransparency = 0.3,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        BorderSizePixel = 0,
        Visible = false,
        Parent = self.ContentArea,
    })
    Util.AddPadding(contentPage, 10, 10, 10, 10)

    -- [FIX #4] Two-column container with manual height sync
    local columnsContainer = Util.Create("Frame", {
        Name = "Columns",
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        Parent = contentPage,
    })

    local leftColumn = Util.Create("Frame", {
        Name = "LeftColumn",
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0.5, -5, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = columnsContainer,
    })
    local leftLayout = Util.AddListLayout(leftColumn, Enum.FillDirection.Vertical, 8)

    local rightColumn = Util.Create("Frame", {
        Name = "RightColumn",
        Position = UDim2.new(0.5, 5, 0, 0),
        Size = UDim2.new(0.5, -5, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = columnsContainer,
    })
    local rightLayout = Util.AddListLayout(rightColumn, Enum.FillDirection.Vertical, 8)

    -- [FIX #4] Sync container height = max(left, right)
    local function syncColumnHeight()
        task.defer(function()
            local lh = leftColumn.AbsoluteSize.Y
            local rh = rightColumn.AbsoluteSize.Y
            columnsContainer.Size = UDim2.new(1, 0, 0, math.max(lh, rh))
        end)
    end
    self:_Connect(leftLayout:GetPropertyChangedSignal("AbsoluteContentSize"), syncColumnHeight)
    self:_Connect(rightLayout:GetPropertyChangedSignal("AbsoluteContentSize"), syncColumnHeight)

    local tabData = {
        Name = tabName,
        Category = tabCategory,
        Button = tabButton,
        ActiveBar = activeBar,
        IconDot = iconDot,
        Label = tabLabel,
        Page = contentPage,
        LeftColumn = leftColumn,
        RightColumn = rightColumn,
        Sections = {},
        Order = tabOrder,
    }

    table.insert(self.Tabs, tabData)

    tabButton.MouseEnter:Connect(function()
        if self.ActiveTab ~= tabData then
            Util.Tween(tabButton, {BackgroundTransparency = 0.5}, 0.12)
        end
    end)
    tabButton.MouseLeave:Connect(function()
        if self.ActiveTab ~= tabData then
            Util.Tween(tabButton, {BackgroundTransparency = 1}, 0.12)
        end
    end)
    tabButton.MouseButton1Click:Connect(function()
        self:_SelectTab(tabData)
    end)

    if #self.Tabs == 1 then
        self:_SelectTab(tabData)
    end

    -- [FIX #5 & #6] Single clean AddSection — no duplicate, no dead metatable
    local libRef = self
    local tabObj = {}

    function tabObj:AddSection(sectionConfig)
        return Amberium._AddSection(tabData, sectionConfig, libRef)
    end

    tabData.Object = tabObj
    return tabObj
end

function Amberium:_SelectTab(tabData)
    for _, tab in ipairs(self.Tabs) do
        tab.Page.Visible = false
        Util.Tween(tab.Button, {BackgroundTransparency = 1}, 0.12)
        Util.Tween(tab.ActiveBar, {BackgroundTransparency = 1}, 0.12)
        Util.Tween(tab.IconDot, {BackgroundColor3 = Theme.TextMuted}, 0.12)
        Util.Tween(tab.Label, {TextColor3 = Theme.TextSecondary}, 0.12)
    end

    tabData.Page.Visible = true
    Util.Tween(tabData.Button, {BackgroundTransparency = 0.3}, AnimConfig.TabSpeed)
    Util.Tween(tabData.ActiveBar, {BackgroundTransparency = 0}, AnimConfig.TabSpeed)
    Util.Tween(tabData.IconDot, {BackgroundColor3 = Theme.Accent}, AnimConfig.TabSpeed)
    Util.Tween(tabData.Label, {TextColor3 = Theme.TextPrimary}, AnimConfig.TabSpeed)

    self.ActiveTab = tabData
end

