-- DROPDOWN COMPONENT
-- [FIX #10] Refresh() now rebuilds with full click/hover handlers
-- ═══════════════════════════════════════════════

function Amberium._CreateDropdown(parent, config, sectionData, lib)
    config = config or {}

    local name = config.Name or "Dropdown"
    local options = config.Options or {"Option 1", "Option 2", "Option 3"}
    local default = config.Default or options[1]
    local callback = config.Callback or function() end

    local selected = default
    local isOpen = false

    local container = Util.Create("Frame", {
        Name = "Dropdown_" .. name,
        Size = UDim2.new(1, 0, 0, 52),
        BackgroundTransparency = 1,
        ClipsDescendants = false,
        LayoutOrder = #sectionData.Elements + 1,
        Parent = parent,
    })

    Util.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Theme.TextPrimary,
        TextSize = 12,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = container,
    })

    local dropBtn = Util.Create("TextButton", {
        Name = "DropBtn",
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundColor3 = Theme.InputBg,
        AutoButtonColor = false,
        Text = "",
        Parent = container,
    })
    Util.AddCorner(dropBtn, 6)
    Util.AddStroke(dropBtn, Theme.InputBorder, 1, 0.5)

    local selectedLabel = Util.Create("TextLabel", {
        Name = "SelectedLabel",
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -30, 1, 0),
        BackgroundTransparency = 1,
        Text = selected,
        TextColor3 = Theme.TextSecondary,
        TextSize = 11,
        FontFace = Fonts.Regular,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = dropBtn,
    })

    local arrow = Util.Create("TextLabel", {
        Name = "Arrow",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -10, 0.5, 0),
        Size = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = Theme.TextMuted,
        TextSize = 8,
        Parent = dropBtn,
    })

    local optionsFrame = Util.Create("Frame", {
        Name = "Options",
        Position = UDim2.new(0, 0, 0, 50),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Theme.InputBg,
        ClipsDescendants = true,
        ZIndex = 10,
        Visible = false,
        Parent = container,
    })
    Util.AddCorner(optionsFrame, 6)
    Util.AddStroke(optionsFrame, Theme.InputBorder, 1, 0.4)
    Util.AddListLayout(optionsFrame, Enum.FillDirection.Vertical, 0)
    Util.AddPadding(optionsFrame, 4, 4, 4, 4)

    local function closeDropdown()
        isOpen = false
        Util.Tween(optionsFrame, {Size = UDim2.new(1, 0, 0, 0)}, AnimConfig.DropdownSpeed)
        task.delay(AnimConfig.DropdownSpeed, function()
            optionsFrame.Visible = false
        end)
        Util.Tween(arrow, {Rotation = 0}, AnimConfig.DropdownSpeed)
        container.Size = UDim2.new(1, 0, 0, 52)
    end

    -- [FIX #10] Shared builder used by init AND Refresh()
    local function buildOptionButtons(opts)
        for _, child in ipairs(optionsFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end

        for i, option in ipairs(opts) do
            local optBtn = Util.Create("TextButton", {
                Name = "Opt_" .. option,
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundColor3 = Theme.SidebarItemHover,
                BackgroundTransparency = 1,
                AutoButtonColor = false,
                Text = "",
                LayoutOrder = i,
                ZIndex = 11,
                Parent = optionsFrame,
            })
            Util.AddCorner(optBtn, 4)

            Util.Create("TextLabel", {
                Name = "OptLabel",
                Position = UDim2.new(0, 8, 0, 0),
                Size = UDim2.new(1, -16, 1, 0),
                BackgroundTransparency = 1,
                Text = option,
                TextColor3 = (option == selected) and Theme.TextAccent or Theme.TextSecondary,
                TextSize = 11,
                FontFace = Fonts.Regular,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 11,
                Parent = optBtn,
            })

            optBtn.MouseEnter:Connect(function()
                Util.Tween(optBtn, {BackgroundTransparency = 0.5}, 0.08)
            end)
            optBtn.MouseLeave:Connect(function()
                Util.Tween(optBtn, {BackgroundTransparency = 1}, 0.08)
            end)

            optBtn.MouseButton1Click:Connect(function()
                selected = option
                selectedLabel.Text = option
                callback(option)

                for _, child in ipairs(optionsFrame:GetChildren()) do
                    if child:IsA("TextButton") then
                        local lbl = child:FindFirstChild("OptLabel")
                        if lbl then
                            lbl.TextColor3 = (child.Name == "Opt_" .. option) and Theme.TextAccent or Theme.TextSecondary
                        end
                    end
                end

                closeDropdown()
            end)
        end
    end

    buildOptionButtons(options)

    dropBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            optionsFrame.Visible = true
            local targetHeight = #options * 26 + 8
            Util.Tween(optionsFrame, {Size = UDim2.new(1, 0, 0, targetHeight)}, AnimConfig.DropdownSpeed)
            Util.Tween(arrow, {Rotation = 180}, AnimConfig.DropdownSpeed)
            container.Size = UDim2.new(1, 0, 0, 52 + targetHeight + 4)
        else
            closeDropdown()
        end
    end)

    dropBtn.MouseEnter:Connect(function()
        Util.Tween(dropBtn, {BackgroundColor3 = Theme.BackgroundLight}, 0.1)
    end)
    dropBtn.MouseLeave:Connect(function()
        Util.Tween(dropBtn, {BackgroundColor3 = Theme.InputBg}, 0.1)
    end)

    local dropdownObj = {
        Set = function(_, newVal) selected = newVal; selectedLabel.Text = newVal; callback(newVal) end,
        Get = function() return selected end,
        Refresh = function(_, newOptions) options = newOptions; buildOptionButtons(newOptions) end,
        Instance = container,
    }

    table.insert(sectionData.Elements, dropdownObj)
    if lib then table.insert(lib._allElements, { Name = name, Instance = container }) end
    return dropdownObj
end

