    local pickerPanel = Util.Create("Frame", {
        Name = "PickerPanel",
        Position = UDim2.new(0, 0, 0, 32),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Theme.CardBg,
        ClipsDescendants = true,
        Visible = false,
        ZIndex = 10,
        Parent = container,
    })
    Util.AddCorner(pickerPanel, 6)
    Util.AddStroke(pickerPanel, Theme.CardBorder, 1, 0.4)

    local svBox = Util.Create("TextButton", {
        Name = "SVBox",
        Position = UDim2.new(0, 8, 0, 8),
        Size = UDim2.new(1, -16, 0, 100),
        BackgroundColor3 = Color3.fromHSV(h, 1, 1),
        AutoButtonColor = false,
        Text = "",
        ZIndex = 11,
        Parent = pickerPanel,
    })
    Util.AddCorner(svBox, 4)

    Util.Create("UIGradient", {
        Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.new(1, 1, 1)),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Parent = svBox,
    })

    local blackOverlay = Util.Create("Frame", {
        Name = "BlackOverlay",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.new(0, 0, 0),
        ZIndex = 12,
        Parent = svBox,
    })
    Util.AddCorner(blackOverlay, 4)
    Util.Create("UIGradient", {
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Rotation = 90,
        Parent = blackOverlay,
    })

    -- [FIX #9] Cursor at correct initial position
    local svCursor = Util.Create("Frame", {
        Name = "SVCursor",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(s, 0, 1 - v, 0),
        Size = UDim2.new(0, 12, 0, 12),
        BackgroundTransparency = 1,
        ZIndex = 13,
        Parent = svBox,
    })
    Util.AddStroke(svCursor, Color3.new(1, 1, 1), 2)
    Util.AddCorner(svCursor, 6)

    local hueBar = Util.Create("TextButton", {
        Name = "HueBar",
        Position = UDim2.new(0, 8, 0, 114),
        Size = UDim2.new(1, -16, 0, 14),
        BackgroundColor3 = Color3.new(1, 1, 1),
        AutoButtonColor = false,
        Text = "",
        ZIndex = 11,
        Parent = pickerPanel,
    })
    Util.AddCorner(hueBar, 4)
    Util.Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
            ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
            ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
            ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
        }),
        Parent = hueBar,
    })

    -- [FIX #9] Hue cursor at correct initial position
    local hueCursor = Util.Create("Frame", {
        Name = "HueCursor",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(h, 0, 0.5, 0),
        Size = UDim2.new(0, 4, 0, 18),
        BackgroundColor3 = Color3.new(1, 1, 1),
        ZIndex = 12,
        Parent = hueBar,
    })
    Util.AddCorner(hueCursor, 2)

    -- RGB inputs
    local rgbRow = Util.Create("Frame", {
        Name = "RGBRow",
        Position = UDim2.new(0, 8, 0, 134),
        Size = UDim2.new(1, -16, 0, 22),
        BackgroundTransparency = 1,
        ZIndex = 11,
        Parent = pickerPanel,
    })

    local rgbLabels = {"R", "G", "B"}
    local rgbBoxes = {}

    for i, channel in ipairs(rgbLabels) do
        Util.Create("TextLabel", {
            Position = UDim2.new((i - 1) / 3, 0, 0, 0),
            Size = UDim2.new(0, 12, 1, 0),
            BackgroundTransparency = 1,
            Text = channel,
            TextColor3 = Theme.TextMuted,
            TextSize = 10,
            FontFace = Fonts.Medium,
            ZIndex = 11,
            Parent = rgbRow,
        })

        local rgbInput = Util.Create("TextBox", {
            Position = UDim2.new((i - 1) / 3, 14, 0, 0),
            Size = UDim2.new(1 / 3, -18, 1, 0),
            BackgroundColor3 = Theme.InputBg,
            Text = tostring(math.floor(({currentColor.R, currentColor.G, currentColor.B})[i] * 255)),
            TextColor3 = Theme.TextPrimary,
            TextSize = 10,
            FontFace = Fonts.Regular,
            TextXAlignment = Enum.TextXAlignment.Center,
            ClearTextOnFocus = true,
            ZIndex = 11,
            Parent = rgbRow,
        })
        Util.AddCorner(rgbInput, 4)
        table.insert(rgbBoxes, rgbInput)
    end

    local function updateColorFromHSV()
        currentColor = Color3.fromHSV(h, s, v)
        previewBtn.BackgroundColor3 = currentColor
        svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
        hueCursor.Position = UDim2.new(h, 0, 0.5, 0)
        rgbBoxes[1].Text = tostring(math.floor(currentColor.R * 255))
        rgbBoxes[2].Text = tostring(math.floor(currentColor.G * 255))
        rgbBoxes[3].Text = tostring(math.floor(currentColor.B * 255))
        callback(currentColor)
    end

    local svDragging = false
    local hueDragging = false

    blackOverlay.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
        end
    end)

    hueBar.MouseButton1Down:Connect(function()
        hueDragging = true
    end)

    -- [FIX #7] Stored connections for both SV and hue dragging
    if lib then
        lib:_Connect(UserInputService.InputEnded, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                svDragging = false
                hueDragging = false
            end
        end)

        lib:_Connect(UserInputService.InputChanged, function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end

            if svDragging then
                local relX = math.clamp((input.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                local relY = math.clamp((input.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                s = relX
                v = 1 - relY
                updateColorFromHSV()
            elseif hueDragging then
                local relX = math.clamp((input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                h = relX
                updateColorFromHSV()
            end
        end)
    end

    for _, box in ipairs(rgbBoxes) do
        box.FocusLost:Connect(function()
            local val = math.clamp(tonumber(box.Text) or 0, 0, 255)
            box.Text = tostring(val)
            local r = tonumber(rgbBoxes[1].Text) / 255
            local g = tonumber(rgbBoxes[2].Text) / 255
            local b = tonumber(rgbBoxes[3].Text) / 255
            currentColor = Color3.new(r, g, b)
            h, s, v = currentColor:ToHSV()
            updateColorFromHSV()
        end)
    end

    previewBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            pickerPanel.Visible = true
            Util.Tween(pickerPanel, {Size = UDim2.new(1, 0, 0, 164)}, AnimConfig.DropdownSpeed)
            container.Size = UDim2.new(1, 0, 0, 200)
        else
            Util.Tween(pickerPanel, {Size = UDim2.new(1, 0, 0, 0)}, AnimConfig.DropdownSpeed)
            task.delay(AnimConfig.DropdownSpeed, function()
                pickerPanel.Visible = false
            end)
            container.Size = UDim2.new(1, 0, 0, 28)
        end
    end)

    local pickerObj = {
        Set = function(_, color) currentColor = color; h, s, v = color:ToHSV(); updateColorFromHSV() end,
        Get = function() return currentColor end,
        Instance = container,
    }

    table.insert(sectionData.Elements, pickerObj)
    if lib then table.insert(lib._allElements, { Name = name, Instance = container }) end
    return pickerObj
end

