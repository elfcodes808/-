function Amberium.new(config)
    config = config or {}

    local self = setmetatable({}, Amberium)

    self.Title = config.Title or "AMBERIUM"
    self.Size = config.Size or UDim2.new(0, 680, 0, 480)
    self.Position = config.Position or UDim2.new(0.5, -340, 0.5, -240)
    self.MinimizeKey = config.MinimizeKey or Enum.KeyCode.RightShift
    self.Theme = Theme
    self.Tabs = {}
    self.ActiveTab = nil
    self.Minimized = false
    self.Connections = {}
    self.Flags = {}
    self._allElements = {} -- for search filtering

    self:_BuildUI()
    self:_SetupKeybinds()
    self:_SetupSearch()

    return self
end

-- [FIX #7] Helper: store a connection for cleanup on Destroy()
function Amberium:_Connect(signal, fn)
    local conn = signal:Connect(fn)
    table.insert(self.Connections, conn)
    return conn
end

